{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "resources/**/*",
        "outDir": "dist"
      },
      {
        "include": "modules/proforma/templates/**/*",
        "outDir": "dist/modules/proforma",
        "watchAssets": true
      }
    ]
  }
}
